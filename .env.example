# Configuration for Deep Research Agent

# ============================================================================
# API KEYS
# ============================================================================

# Gemini API Key (REQUIRED)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Custom Search API (OPTIONAL - for better search results)
# Get API key at: https://console.cloud.google.com/apis/credentials
# Create search engine at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_CX=your-search-engine-id

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Maximum number of sources to index per research query
MAX_SOURCES=20

# Maximum concurrent web requests
MAX_CONCURRENT_REQUESTS=10

# Request timeout in seconds
REQUEST_TIMEOUT=15

# Embedding model (sentence-transformers model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Model
LLM_MODEL=gemini-1.5-pro

# LLM Temperature (0.0 to 1.0)
LLM_TEMPERATURE=0.7

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Enable caching for repeated queries
ENABLE_CACHE=true

# Cache expiration in hours
CACHE_EXPIRATION_HOURS=24

# Maximum content length per source (characters)
MAX_CONTENT_LENGTH=5000

# Number of subtasks to generate (min-max range)
MIN_SUBTASKS=3
MAX_SUBTASKS=7

# ============================================================================
# OUTPUT SETTINGS
# ============================================================================

# Export results automatically
AUTO_EXPORT=false

# Export directory
EXPORT_DIR=./research_results

# Include performance metrics in export
INCLUDE_METRICS=true

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================

# Number of search results per subtask
RESULTS_PER_SEARCH=10

# Retry failed requests
RETRY_FAILED_REQUESTS=true

# Max retries
MAX_RETRIES=3

# ============================================================================
# VECTOR INDEX SETTINGS
# ============================================================================

# Vector index type (faiss, pinecone, weaviate)
VECTOR_INDEX_TYPE=faiss

# Number of top documents to retrieve
TOP_K_RETRIEVAL=10

# ============================================================================
# LOGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/research_agent.log

# Enable performance logging
ENABLE_PERFORMANCE_LOGGING=true
